{
    "name": "fullstack-todo-app",
    "version": "1.0.0",
    "description": "A full-stack todo application",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "cd api && node server.js",
        "dev:frontend": "cd frontend && npm start",
        "build": "cd api && npm install && cd ../frontend && npm install && npm run build",
        "start": "cd api && node server.js"
    },
    "devDependencies": {
        "concurrently": "^9.1.0"
    }
}